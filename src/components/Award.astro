---
import { Image } from "astro:assets";
import ceremonyImg from "../images/About 2.jpg";

const ceremonyImage = ceremonyImg;
const whatsappUrl = "https://wa.me/447777399135?text=Hi%20Uzma%2C%20I%27d%20like%20to%20book%20a%20bridal%20consultation";
---

<section
  id="award"
  class="relative py-24 md:py-32 lg:py-40 overflow-hidden"
  style="background-color: var(--color-burgundy); color: var(--color-ivory);"
>
  <!-- Background portrait -->
  <div class="absolute inset-0 opacity-[0.18]">
    <Image
      src={ceremonyImage}
      alt=""
      width={1600}
      height={1067}
      loading="lazy"
      decoding="async"
      class="w-full h-full object-cover"
      aria-hidden="true"
    />
  </div>

  <!-- Burgundy radial veil -->
  <div
    class="absolute inset-0"
    style="background: radial-gradient(ellipse at center, rgba(123,28,42,0.5) 0%, var(--color-burgundy) 70%);"
    aria-hidden="true"
  ></div>

  <!-- Decorative gold corners -->
  <div class="absolute top-10 left-10 w-20 h-20 border-l-2 border-t-2 hidden md:block opacity-60" style="border-color: var(--color-gold);" aria-hidden="true"></div>
  <div class="absolute top-10 right-10 w-20 h-20 border-r-2 border-t-2 hidden md:block opacity-60" style="border-color: var(--color-gold);" aria-hidden="true"></div>
  <div class="absolute bottom-10 left-10 w-20 h-20 border-l-2 border-b-2 hidden md:block opacity-60" style="border-color: var(--color-gold);" aria-hidden="true"></div>
  <div class="absolute bottom-10 right-10 w-20 h-20 border-r-2 border-b-2 hidden md:block opacity-60" style="border-color: var(--color-gold);" aria-hidden="true"></div>

  <div class="relative max-w-6xl mx-auto px-6 lg:px-12 text-center">
    <!-- Award medallion -->
    <div class="flex justify-center mb-10">
      <div class="relative">
        <svg width="120" height="120" viewBox="0 0 120 120" fill="none" aria-hidden="true">
          <!-- Outer ring -->
          <circle cx="60" cy="60" r="58" stroke="var(--color-gold)" stroke-width="0.7" stroke-dasharray="2 3"/>
          <!-- Inner ring -->
          <circle cx="60" cy="60" r="48" stroke="var(--color-gold)" stroke-width="1"/>
          <!-- Star -->
          <path
            d="M60 30 L65.5 51.5 L87 53 L70 67 L76 88 L60 75 L44 88 L50 67 L33 53 L54.5 51.5 Z"
            fill="var(--color-gold)"
            stroke="var(--color-gold-deep)"
            stroke-width="0.5"
          />
          <!-- Decorative dots -->
          <circle cx="60" cy="8" r="2" fill="var(--color-gold)"/>
          <circle cx="60" cy="112" r="2" fill="var(--color-gold)"/>
          <circle cx="8" cy="60" r="2" fill="var(--color-gold)"/>
          <circle cx="112" cy="60" r="2" fill="var(--color-gold)"/>
        </svg>
        <div class="absolute inset-0 rounded-full" style="box-shadow: 0 0 60px rgba(201,168,76,0.4);"></div>
      </div>
    </div>

    <p class="eyebrow mb-6" style="color: var(--color-gold);">
      National Recognition · 2010
    </p>

    <h2
      class="font-light leading-[0.95] mb-8 text-[clamp(2.5rem,6vw,5rem)]"
      style="font-family: var(--font-heading); color: var(--color-ivory);"
    >
      Winner of the
      <em class="italic block" style="color: var(--color-gold); font-style: italic;">All Pakistan Bridal Competition</em>
      <span class="text-[0.7em] block mt-3" style="color: rgba(250,246,240,0.85);">presented by the First Lady of Pakistan.</span>
    </h2>

    <p class="max-w-2xl mx-auto text-lg leading-relaxed mb-12" style="color: rgba(250,246,240,0.85); font-weight: 300;">
      In 2010, SolaSinghar's signature bridal artistry was honoured at the highest stage in Pakistan —
      a moment that continues to define the standards held at every chair, on every wedding morning.
    </p>

    <!-- Stat trio -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-4 max-w-4xl mx-auto mb-14">
      <div class="relative pt-6">
        <div
          class="absolute top-0 left-1/2 -translate-x-1/2 w-12 h-px"
          style="background-color: var(--color-gold);"
        ></div>
        <div
          class="text-5xl md:text-6xl font-light mb-2"
          style="font-family: var(--font-heading); color: var(--color-gold);"
        >
          700+
        </div>
        <div
          class="text-xs uppercase tracking-[0.3em]"
          style="color: rgba(250,246,240,0.85);"
        >
          Brides served since 2008
        </div>
      </div>

      <div class="relative pt-6 md:border-l md:border-r" style="border-color: rgba(201,168,76,0.4);">
        <div
          class="absolute top-0 left-1/2 -translate-x-1/2 w-12 h-px"
          style="background-color: var(--color-gold);"
        ></div>
        <div
          class="text-5xl md:text-6xl font-light mb-2"
          style="font-family: var(--font-heading); color: var(--color-gold);"
        >
          ★
        </div>
        <div
          class="text-xs uppercase tracking-[0.3em]"
          style="color: rgba(250,246,240,0.85);"
        >
          National award winner · 2010
        </div>
      </div>

      <div class="relative pt-6">
        <div
          class="absolute top-0 left-1/2 -translate-x-1/2 w-12 h-px"
          style="background-color: var(--color-gold);"
        ></div>
        <div
          class="text-5xl md:text-6xl font-light mb-2"
          style="font-family: var(--font-heading); color: var(--color-gold);"
        >
          17+
        </div>
        <div
          class="text-xs uppercase tracking-[0.3em]"
          style="color: rgba(250,246,240,0.85);"
        >
          Years of bridal experience
        </div>
      </div>
    </div>

    <a href={whatsappUrl} target="_blank" rel="noopener noreferrer" class="btn-outline">
      <span>Reserve Your Date</span>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
        <line x1="5" y1="12" x2="19" y2="12"/>
        <polyline points="13 6 19 12 13 18"/>
      </svg>
    </a>
  </div>
</section>
