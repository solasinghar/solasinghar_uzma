---
const year = new Date().getFullYear();
const whatsappUrl = "https://wa.me/923135022787";
---

<footer
  class="relative pt-20 pb-10"
  style="background-color: var(--color-charcoal); color: var(--color-ivory);"
>
  <!-- Top gold ornament -->
  <div class="absolute top-0 inset-x-0 h-px" style="background: linear-gradient(90deg, transparent, var(--color-gold), transparent);"></div>

  <div class="max-w-7xl mx-auto px-6 lg:px-12">
    <!-- Top row -->
    <div class="grid md:grid-cols-12 gap-10 md:gap-12 pb-14 mb-14 border-b" style="border-color: rgba(201,168,76,0.18);">
      <!-- Brand -->
      <div class="md:col-span-5">
        <div class="flex flex-col leading-none mb-6">
          <span
            class="text-3xl tracking-[0.18em] uppercase font-light"
            style="font-family: var(--font-heading); color: var(--color-ivory);"
          >
            Sola<span style="color: var(--color-gold);">Singhar</span>
          </span>
          <span
            class="text-[10px] tracking-[0.4em] uppercase mt-1"
            style="color: var(--color-gold-soft);"
          >
            by Uzma · Est. 2008
          </span>
        </div>

        <p class="text-sm leading-relaxed max-w-md" style="color: rgba(250,246,240,0.65);">
          Award-winning Pakistani bridal artistry, near Java Road, Rawat–Islamabad.
          Trusted by 700+ brides since 2008. Honoured by the First Lady of Pakistan in 2010.
        </p>
      </div>

      <!-- Nav -->
      <div class="md:col-span-3">
        <div class="text-[11px] uppercase tracking-[0.32em] mb-5" style="color: var(--color-gold);">
          Studio
        </div>
        <ul class="space-y-3 text-sm" style="color: rgba(250,246,240,0.75);">
          <li><a href="#about" class="nav-link transition-colors duration-500 hover:text-[var(--color-gold)]">About</a></li>
          <li><a href="#services" class="nav-link transition-colors duration-500 hover:text-[var(--color-gold)]">Services</a></li>
          <li><a href="#gallery" class="nav-link transition-colors duration-500 hover:text-[var(--color-gold)]">Gallery</a></li>
          <li><a href="#award" class="nav-link transition-colors duration-500 hover:text-[var(--color-gold)]">Recognition</a></li>
          <li><a href="#testimonials" class="nav-link transition-colors duration-500 hover:text-[var(--color-gold)]">Brides</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div class="md:col-span-4">
        <div class="text-[11px] uppercase tracking-[0.32em] mb-5" style="color: var(--color-gold);">
          Contact
        </div>
        <address class="not-italic text-sm leading-relaxed mb-5" style="color: rgba(250,246,240,0.75);">
          Near Java Road, Rawat<br />
          Islamabad, Pakistan
        </address>
        <a
          href={whatsappUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 text-sm transition-colors duration-500 hover:text-[var(--color-gold)]"
          style="color: rgba(250,246,240,0.85);"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
          </svg>
          +313 5022787
        </a>

        <!-- Socials -->
        <div class="mt-8 flex gap-3">
          <a
            href="https://instagram.com"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Instagram"
            class="w-10 h-10 flex items-center justify-center border transition-colors duration-500"
            style="border-color: rgba(201,168,76,0.35); color: rgba(250,246,240,0.7);"
            onmouseover="this.style.borderColor='var(--color-gold)'; this.style.color='var(--color-gold)';"
            onmouseout="this.style.borderColor='rgba(201,168,76,0.35)'; this.style.color='rgba(250,246,240,0.7)';"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <rect x="2" y="2" width="20" height="20" rx="5"/>
              <circle cx="12" cy="12" r="4"/>
              <circle cx="17.5" cy="6.5" r="0.7" fill="currentColor"/>
            </svg>
          </a>
          <a
            href="https://facebook.com"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Facebook"
            class="w-10 h-10 flex items-center justify-center border transition-colors duration-500"
            style="border-color: rgba(201,168,76,0.35); color: rgba(250,246,240,0.7);"
            onmouseover="this.style.borderColor='var(--color-gold)'; this.style.color='var(--color-gold)';"
            onmouseout="this.style.borderColor='rgba(201,168,76,0.35)'; this.style.color='rgba(250,246,240,0.7)';"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
              <path d="M22 12c0-5.52-4.48-10-10-10S2 6.48 2 12c0 4.84 3.44 8.87 8 9.8V15H8v-3h2V9.5C10 7.57 11.57 6 13.5 6H16v3h-2c-.55 0-1 .45-1 1v2h3v3h-3v6.95c5.05-.5 9-4.76 9-9.95Z"/>
            </svg>
          </a>
          <a
            href={whatsappUrl}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="WhatsApp"
            class="w-10 h-10 flex items-center justify-center border transition-colors duration-500"
            style="border-color: rgba(201,168,76,0.35); color: rgba(250,246,240,0.7);"
            onmouseover="this.style.borderColor='var(--color-gold)'; this.style.color='var(--color-gold)';"
            onmouseout="this.style.borderColor='rgba(201,168,76,0.35)'; this.style.color='rgba(250,246,240,0.7)';"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
            </svg>
          </a>
        </div>
      </div>
    </div>

    <!-- Bottom row -->
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 text-[11px] uppercase tracking-[0.28em]" style="color: rgba(250,246,240,0.45);">
      <span>© {year} SolaSinghar by Uzma · All rights reserved</span>
      <span class="flex items-center gap-2">
        <svg width="12" height="12" viewBox="0 0 12 12" aria-hidden="true">
          <circle cx="6" cy="6" r="2" fill="var(--color-gold)"/>
        </svg>
        Crafted with riwayat in Rawat
      </span>
    </div>
  </div>
</footer>
