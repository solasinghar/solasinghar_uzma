---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "SolaSinghar by Uzma — Award-Winning Bridal Studio, Islamabad",
  description = "Trusted by 700+ brides since 2008. Award-winning bridal makeup, mehndi, hair & party makeup near Java Road, Rawat, Islamabad. Book your consultation via WhatsApp.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#7B1C2A" />

    <!-- Favicons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />

    <!-- Google Fonts: Cormorant Garamond (heading) + DM Sans (body) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,500&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300;1,9..40,400&display=swap"
      rel="stylesheet"
    />

  </head>

  <body class="antialiased">
    <slot />
  </body>
</html>
