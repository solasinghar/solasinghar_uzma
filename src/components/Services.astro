---
import { Image } from "astro:assets";
import bridalImg from "../images/Bridal2.jpg";
import mehndiBImg from "../images/Henna1.jpg";
import hairImg from "../images/Makeup.jpg";
import partyImg from "../images/Partymakeup1.jpg";

const whatsappBase = "https://wa.me/447777399135?text=";

const services = [
  {
    name: "Bridal Makeup",
    tagline: "Signature",
    urdu: "Dulhan",
    num: "01",
    description:
      "Hand-blended foundations, dewy skin finishes and editorial eye work — engineered to photograph as beautifully as it feels in person.",
    image: bridalImg,
    alt: "Pakistani bride in red and gold lehenga with traditional jewelry",
    book:
      whatsappBase +
      encodeURIComponent("Hi Uzma, I'd like to enquire about the Bridal Makeup package."),
  },
  {
    name: "Mehndi",
    tagline: "Riwayat",
    urdu: "Henna",
    num: "02",
    description:
      "Intricate freehand henna — bold motifs, fine line work and personal initials hidden inside the patterns. Designed for the dholki, mehndi or barat.",
    image: mehndiBImg,
    alt: "Detailed bridal mehndi henna patterns on hands",
    book:
      whatsappBase +
      encodeURIComponent("Hi Uzma, I'd like to enquire about Mehndi for an upcoming event."),
  },
  {
    name: "Hair Styling",
    tagline: "Jura · Curls",
    urdu: "Sajawat",
    num: "03",
    description:
      "Sculpted updos, classic curls and flower-set juras anchored to last through the longest baraat — finished with traditional matha-patti placement.",
    image: hairImg,
    alt: "Elegant bridal hair styling with traditional accessories",
    book:
      whatsappBase +
      encodeURIComponent("Hi Uzma, I'd like to enquire about Hair Styling."),
  },
  {
    name: "Party Makeup",
    tagline: "Mehfil",
    urdu: "Shaam",
    num: "04",
    description:
      "For the dholki, the engagement, the cocktail. A lighter, lit-from-within finish that still reads from the back of the room — and stays put past midnight.",
    image: partyImg,
    alt: "Elegant evening party makeup for South Asian client",
    book:
      whatsappBase +
      encodeURIComponent("Hi Uzma, I'd like to enquire about Party Makeup."),
  },
];
---

<section id="services" class="svc-section">

  <!-- Top ornamental border -->
  <div class="svc-border-top" aria-hidden="true"></div>

  <div class="svc-inner">

    <!-- ── SECTION HEADER ── -->
    <div class="svc-header">

      <!-- Ornament -->
      <div class="svc-orn" aria-hidden="true">
        <svg width="48" height="12" viewBox="0 0 48 12" fill="none">
          <line x1="0" y1="6" x2="16" y2="6" stroke="#D4AF37" stroke-width="0.8" opacity="0.6"/>
          <circle cx="24" cy="6" r="3" stroke="#D4AF37" stroke-width="0.8" opacity="0.8"/>
          <circle cx="24" cy="6" r="1.2" fill="#D4AF37" opacity="0.9"/>
          <line x1="32" y1="6" x2="48" y2="6" stroke="#D4AF37" stroke-width="0.8" opacity="0.6"/>
        </svg>
      </div>

      <p class="svc-eyebrow">The Studio · Services</p>

      <h2 class="svc-heading">
        Four signature rituals,
        <em class="svc-heading-em">crafted for the modern bride.</em>
      </h2>

      <div class="svc-rule" aria-hidden="true"></div>

      <p class="svc-subtext">
        Every service is a private, by-appointment experience at the Rawat studio —
        with on-location options for the wedding morning and select destination weddings.
      </p>

    </div>
    <!-- END HEADER -->

    <!-- ── CARD GRID ── -->
    <div class="svc-grid">
      {services.map((service) => (
        <article class="svc-card">

          <!-- Image zone -->
          <div class="svc-img-wrap">
            <Image
              src={service.image}
              alt={service.alt}
              width={800}
              height={1067}
              loading="lazy"
              decoding="async"
              class="svc-img"
            />

            <!-- Warm parchment overlay to blend image into section bg -->
            <div class="svc-img-overlay" aria-hidden="true"></div>

            <!-- Bottom fade into card body -->
            <div class="svc-img-fade" aria-hidden="true"></div>

            <!-- Number -->
            <span class="svc-num">{service.num}</span>

            <!-- Tagline pill -->
            <span class="svc-pill">{service.tagline}</span>
          </div>

          <!-- Card body -->
          <div class="svc-body">

            <!-- Urdu word -->
            <p class="svc-urdu">{service.urdu}</p>

            <!-- Service name -->
            <h3 class="svc-name">{service.name}</h3>

            <!-- Gold micro-rule -->
            <div class="svc-card-rule" aria-hidden="true"></div>

            <!-- Description -->
            <p class="svc-desc">{service.description}</p>

            <!-- Enquire link -->
            <a
              href={service.book}
              target="_blank"
              rel="noopener noreferrer"
              class="svc-link"
              aria-label={`Enquire about ${service.name}`}
            >
              <span>Enquire</span>
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <line x1="5" y1="12" x2="19" y2="12"/>
                <polyline points="13 6 19 12 13 18"/>
              </svg>
            </a>

          </div>
        </article>
      ))}
    </div>
    <!-- END GRID -->

    <!-- Footer note -->
    <p class="svc-footer-note">
      ✦ &nbsp; Bespoke packages available · Bridal trials by appointment &nbsp; ✦
    </p>

  </div>

  <!-- Bottom ornamental border -->
  <div class="svc-border-bottom" aria-hidden="true"></div>

</section>


<style>
/* ─────────────────────────────────────────
   SECTION ROOT
   ───────────────────────────────────────── */
.svc-section {
  position: relative;
  background-color: #EAE0C8;
  padding: 6rem 0 5rem;
}

.svc-border-top,
.svc-border-bottom {
  position: absolute;
  inset-x: 0;
  height: 1px;
  background: linear-gradient(90deg, transparent 0%, #D4AF37 30%, #D4AF37 70%, transparent 100%);
  opacity: 0.45;
}
.svc-border-top    { top: 0; }
.svc-border-bottom { bottom: 0; }

.svc-inner {
  max-width: 1280px;
  margin: 0 auto;
  padding: 0 1.5rem;
}
@media (min-width: 1024px) {
  .svc-inner { padding: 0 3rem; }
}

/* ─────────────────────────────────────────
   SECTION HEADER
   ───────────────────────────────────────── */
.svc-header {
  max-width: 680px;
  margin: 0 auto 4.5rem;
  text-align: center;
}

.svc-orn {
  display: flex;
  justify-content: center;
  margin-bottom: 1.4rem;
}

.svc-eyebrow {
  font-family: 'DM Sans', sans-serif;
  font-size: clamp(.58rem, .9vw, .68rem);
  font-weight: 500;
  letter-spacing: .38em;
  text-transform: uppercase;
  color: #7B1C2A;
  margin-bottom: 1.2rem;
}

.svc-heading {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(1.9rem, 3.8vw, 3rem);
  font-weight: 300;
  line-height: 1.2;
  color: #120A0D;
  margin-bottom: 0;
}
.svc-heading-em {
  font-style: italic;
  color: #7B1C2A;
}

.svc-rule {
  width: 48px;
  height: 1px;
  background: linear-gradient(90deg, transparent, #D4AF37, transparent);
  margin: 1.8rem auto;
  opacity: 0.7;
}

.svc-subtext {
  font-family: 'DM Sans', sans-serif;
  font-size: clamp(.82rem, 1.2vw, .95rem);
  font-weight: 300;
  line-height: 1.85;
  color: rgba(18, 10, 13, 0.6);
}

/* ─────────────────────────────────────────
   CARD GRID
   ───────────────────────────────────────── */
.svc-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1.5rem;
}

@media (min-width: 1024px) {
  .svc-grid {
    grid-template-columns: repeat(4, 1fr);
    gap: 1.75rem;
  }
}

/* ─────────────────────────────────────────
   CARD
   ───────────────────────────────────────── */
.svc-card {
  display: flex;
  flex-direction: column;
  background: #120A0D;
  border: 1px solid rgba(212,175,55,0.2);
  overflow: hidden;
  transition: transform .5s cubic-bezier(.19,1,.22,1),
              box-shadow .5s cubic-bezier(.19,1,.22,1),
              border-color .5s ease;
}
.svc-card:hover {
  transform: translateY(-6px);
  box-shadow: 0 20px 50px rgba(18,10,13,0.25);
  border-color: rgba(212,175,55,0.5);
}

/* ── IMAGE ── */
.svc-img-wrap {
  position: relative;
  aspect-ratio: 3 / 4;
  overflow: hidden;
}
.svc-img {
  width: 100% !important;
  height: 100% !important;
  max-width: none !important;
  object-fit: cover;
  filter: brightness(0.88) saturate(0.9);
  transition: transform .9s cubic-bezier(.19,1,.22,1), filter .5s ease;
}
.svc-card:hover .svc-img {
  transform: scale(1.04);
  filter: brightness(0.95) saturate(1);
}

/* Warm parchment colour overlay — blends image tone into section bg */
.svc-img-overlay {
  position: absolute;
  inset: 0;
  background: rgba(234,224,200,0.08);
  pointer-events: none;
}

/* Bottom fade: image melts into dark card body */
.svc-img-fade {
  position: absolute;
  inset-x: 0;
  bottom: 0;
  height: 55%;
  background: linear-gradient(to bottom, transparent 0%, #120A0D 100%);
  pointer-events: none;
}

/* Number */
.svc-num {
  position: absolute;
  top: .9rem;
  left: 1rem;
  font-family: 'DM Sans', sans-serif;
  font-size: .55rem;
  font-weight: 500;
  letter-spacing: .28em;
  color: #D4AF37;
  opacity: .8;
}

/* Tagline pill */
.svc-pill {
  position: absolute;
  top: .85rem;
  right: .9rem;
  font-family: 'DM Sans', sans-serif;
  font-size: .5rem;
  font-weight: 500;
  letter-spacing: .22em;
  text-transform: uppercase;
  color: #FAF6F0;
  background: rgba(123,28,42,0.8);
  border: 1px solid rgba(212,175,55,0.4);
  padding: .28rem .6rem;
  backdrop-filter: blur(4px);
}

/* ── CARD BODY ── */
.svc-body {
  padding: 1.25rem 1.4rem 1.6rem;
  display: flex;
  flex-direction: column;
  flex: 1;
}

.svc-urdu {
  font-family: 'Cormorant Garamond', serif;
  font-size: .75rem;
  font-style: italic;
  letter-spacing: .12em;
  color: #D4AF37;
  margin-bottom: .3rem;
  opacity: .8;
}

.svc-name {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(1.25rem, 2vw, 1.6rem);
  font-weight: 300;
  color: #FAF6F0;
  line-height: 1.1;
  margin-bottom: 0;
}

.svc-card-rule {
  width: 28px;
  height: 1px;
  background: linear-gradient(90deg, #D4AF37, transparent);
  opacity: .55;
  margin: .9rem 0;
}

.svc-desc {
  font-family: 'DM Sans', sans-serif;
  font-size: clamp(.72rem, 1.1vw, .8rem);
  font-weight: 300;
  line-height: 1.8;
  color: rgba(250,246,240,0.6);
  flex: 1;
  margin-bottom: 1.3rem;
}

.svc-link {
  display: inline-flex;
  align-items: center;
  gap: .4rem;
  font-family: 'DM Sans', sans-serif;
  font-size: .55rem;
  font-weight: 500;
  letter-spacing: .26em;
  text-transform: uppercase;
  text-decoration: none;
  color: #D4AF37;
  transition: color .4s ease, gap .4s ease;
}
.svc-link:hover {
  color: #FAF6F0;
  gap: .7rem;
}

/* ─────────────────────────────────────────
   FOOTER NOTE
   ───────────────────────────────────────── */
.svc-footer-note {
  margin-top: 4rem;
  text-align: center;
  font-family: 'DM Sans', sans-serif;
  font-size: .58rem;
  letter-spacing: .3em;
  text-transform: uppercase;
  color: rgba(18,10,13,0.45);
}

/* ─────────────────────────────────────────
   MOBILE
   ───────────────────────────────────────── */
@media (max-width: 640px) {
  .svc-section  { padding: 4rem 0 3.5rem; }
  .svc-header   { margin-bottom: 3rem; }
  .svc-grid     { grid-template-columns: 1fr; gap: 1.25rem; }

  .svc-img-wrap { aspect-ratio: 4 / 3; }
  .svc-body     { padding: 1rem 1.1rem 1.3rem; }
}
</style>
