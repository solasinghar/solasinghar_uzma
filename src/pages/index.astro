---
import "../styles/global.css";
import Navbar      from "../components/Navbar.astro";
import Hero        from "../components/Hero.astro";
import About       from "../components/About.astro";
import Services    from "../components/Services.astro";
import Award       from "../components/Award.astro";
import Gallery     from "../components/Gallery.astro";
import Testimonials from "../components/Testimonials.astro";
import Contact     from "../components/Contact.astro";
import Footer      from "../components/Footer.astro";

const siteTitle =
  "SolaSinghar by Uzma — Best Bridal Makeup in Rawat & Islamabad | Award-Winning Pakistani Bridal Artistry";
const siteDescription =
  "Award-winning Pakistani bridal makeup, mehndi & hair styling near Java Road, Rawat–Islamabad. Trusted by 700+ brides since 2008. Winner of the All Pakistan Bridal Competition 2010, presented by the First Lady of Pakistan. Book on WhatsApp.";
const canonical = "https://solasinghar.github.io/solasinghar_uzma/";
const ogImage = "https://solasinghar.github.io/solasinghar_uzma/og-image.jpg";

// Schema.org LocalBusiness JSON-LD — strong local SEO signal
const businessSchema = {
  "@context": "https://schema.org",
  "@type": "BeautySalon",
  "name": "SolaSinghar by Uzma",
  "image": ogImage,
  "description": siteDescription,
  "url": canonical,
  "telephone": "+447777399135",
  "priceRange": "$$$",
  "founder": { "@type": "Person", "name": "Uzma Malik" },
  "foundingDate": "2008",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Near Java Road",
    "addressLocality": "Rawat",
    "addressRegion": "Islamabad Capital Territory",
    "addressCountry": "PK",
  },
  "areaServed": [
    { "@type": "City", "name": "Rawat" },
    { "@type": "City", "name": "Islamabad" },
    { "@type": "City", "name": "Rawalpindi" },
  ],
  "openingHoursSpecification": [
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"],
      "opens": "10:00",
      "closes": "20:00",
    },
  ],
  "award":
    "Winner — All Pakistan Bridal Competition (2010), presented by the First Lady of Pakistan",
  "makesOffer": [
    { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Bridal Makeup" } },
    { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Mehndi (Henna)" } },
    { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Hair Styling" } },
    { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Party Makeup" } },
  ],
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "5.0",
    "reviewCount": "700",
  },
  "sameAs": [
    "https://wa.me/447777399135",
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{siteTitle}</title>
    <meta name="description" content={siteDescription} />
    <meta name="keywords" content="best bridal makeup in Rawat, best bridal makeup Islamabad, Pakistani bridal makeup, bridal artist Islamabad, mehndi designer Rawat, bridal hair stylist Islamabad, SolaSinghar, Uzma Malik, All Pakistan Bridal Competition winner" />
    <meta name="author" content="Uzma Malik · SolaSinghar" />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type"        content="website" />
    <meta property="og:url"         content={canonical} />
    <meta property="og:title"       content={siteTitle} />
    <meta property="og:description" content={siteDescription} />
    <meta property="og:image"       content={ogImage} />
    <meta property="og:locale"      content="en_PK" />
    <meta property="og:site_name"   content="SolaSinghar by Uzma" />

    <!-- Twitter -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={siteTitle} />
    <meta name="twitter:description" content={siteDescription} />
    <meta name="twitter:image"       content={ogImage} />

    <!-- Geo / local -->
    <meta name="geo.region"   content="PK-IS" />
    <meta name="geo.placename" content="Rawat, Islamabad" />
    <meta name="geo.position"  content="33.5128;73.1818" />
    <meta name="ICBM"          content="33.5128, 73.1818" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Theme color -->
    <meta name="theme-color" content="#7B1C2A" />

    <!-- Fonts (Bunny — privacy-friendly Google Fonts mirror) -->
    <link rel="preconnect" href="https://fonts.bunny.net" crossorigin />
    <link
      href="https://fonts.bunny.net/css?family=cormorant-garamond:300,400,500,600,500i,400i|dm-sans:300,400,500,600,700&display=swap"
      rel="stylesheet"
    />

    <!-- Structured data: LocalBusiness -->
    <script type="application/ld+json" set:html={JSON.stringify(businessSchema)} />
  </head>

  <body class="antialiased">
    <Navbar />

    <main>
      <Hero />
      <About />
      <Services />
      <Award />
      <Gallery />
      <Testimonials />
      <Contact />
    </main>

    <Footer />

    <!-- Reveal-on-scroll observer (progressive enhancement) -->
    <script is:inline>
      (() => {
        if (typeof IntersectionObserver === "undefined") return;
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-visible");
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.12, rootMargin: "0px 0px -10% 0px" }
        );
        document.querySelectorAll(".reveal").forEach((el) => observer.observe(el));
      })();
    </script>
  </body>
</html>
