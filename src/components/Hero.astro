---
import { Image } from "astro:assets";
import hero1 from "../images/Hero-1.jpg";
---

<section id="hero" aria-label="SolaSinghar Bridal Artistry">

  <!-- Full-bleed background image -->
  <div class="bg-slides">
    <div class="slide s1">
      <Image src={hero1} alt="SolaSinghar bridal portrait" class="bg-img"
        loading="eager" decoding="sync" fetchpriority="high" />
    </div>
  </div>

  <!-- Scrim: dark on left, fully transparent by 55% -->
  <div class="scrim"></div>

  <!-- Navbar cover: solid dark bar that hides the image
       in the exact zone where the fixed navbar sits.
       No object-position trick can solve this — we simply
       paint over the top 92 px of the image. -->
  <div class="nav-cover" aria-hidden="true"></div>

  <!-- Two-column grid: left = text, right = empty (bride shows through) -->
  <div class="content-grid">

    <!-- LEFT COLUMN -->
    <div class="left-col">

      <!-- ✦ Bridal Makeup ✦ -->
      <div class="h-label" data-r="0">
        <span class="h-orn">✦</span>
        <span class="h-label-text">Bridal Makeup</span>
        <span class="h-orn">✦</span>
      </div>

      <!-- Reimagined as Art. -->
      <h1 class="h-reimagined" data-r="1">Reimagined as Art.</h1>

      <!-- Gold rule -->
      <div class="h-rule" data-r="2"></div>

      <!-- Sola Singhar — the prominent name -->
      <p class="h-brand" data-r="3">Sola Singhar</p>

      <!-- By Uzma Malik — same tone as Reimagined -->
      <p class="h-credit" data-r="4">By Uzma Malik · Est. 2008</p>

      <!-- CTAs -->
      <div class="cta-row" data-r="5">
        <a href="https://wa.me/923135022787?text=Hi%20Uzma%2C%20I%27d%20like%20to%20book%20a%20bridal%20consultation"
           class="btn-fill" target="_blank" rel="noopener noreferrer">
          <svg class="btn-icon" width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
          </svg>
          Book a Consultation
        </a>
        <a href="#services" class="btn-line">
          Our Services
          <span class="btn-arrow">→</span>
        </a>
      </div>

    </div>
    <!-- END LEFT COLUMN -->

    <!-- RIGHT COLUMN: intentionally empty, bride image shows through -->
    <div class="right-col"></div>

  </div>

  <!-- Award badge — sits over the right (bride) side -->
  <div class="award" data-r="7">
    <span class="aw-star">✦</span>
    <span class="aw-t">Award Winner</span>
    <span class="aw-y">2010</span>
  </div>

  <!-- Scroll cue -->
  <div class="scroll-cue">
    <span class="sc-text">Scroll</span>
    <div class="sc-bar"></div>
  </div>

</section>


<style>
/* ────────────────────────────────────────────
   SECTION ROOT
   ──────────────────────────────────────────── */
#hero {
  position: relative;
  width: 100%;
  height: 100dvh;
  min-height: 640px;
  overflow: hidden;
  background: #080808;
}

/* ────────────────────────────────────────────
   BACKGROUND SLIDES
   ──────────────────────────────────────────── */
.bg-slides {
  position: absolute;
  inset: 0;
  z-index: 0;
}
.slide {
  position: absolute;
  inset: 0;
}
.bg-img {
  width: 100% !important;
  height: 100% !important;
  max-width: none !important;
  object-fit: cover;
  /* Push bride right and down — face clear of navbar */
  /* Face sits in upper portion of photo.
     nav-cover hides top 92px, so face appears just below it. */
  /* Portrait crop of bride's side — 65% centres on her face horizontally,
     0% pushes image as far down as possible so face clears the nav-cover */
  object-position: 90% 0%;
}

.s1 { z-index: 1; animation: kb1 20s ease-in-out infinite alternate; }

@keyframes kb1 {
  0%   { transform: scale(1.05) translateX( 8px); }
  100% { transform: scale(1.00) translateX(-8px); }
}

/* ────────────────────────────────────────────
   SCRIM — left only
   ──────────────────────────────────────────── */
.scrim {
  position: absolute;
  inset: 0;
  z-index: 1;
  /* Dark left → transparent right.
     Fully clear from 60 % onward — bride face untouched */
  /* Scrim covers only the left 34% text panel, fades by 55% */
  background: linear-gradient(
    to right,
    #060402         0%,
    rgba(6,4,2,.98) 8%,
    rgba(6,4,2,.93) 22%,
    rgba(6,4,2,.70) 34%,
    rgba(6,4,2,.20) 46%,
    transparent     56%
  );
  pointer-events: none;
}

/* ────────────────────────────────────────────
   NAVBAR COVER — hides image behind fixed nav
   ──────────────────────────────────────────── */
.nav-cover {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  /* Match the navbar's py-6 lg:py-8 + logo height ≈ 92px */
  height: 92px;
  z-index: 6;
  /* Left half: same near-black as the scrim edge — seamless */
  background: linear-gradient(
    to right,
    #060402       0%,
    #060402      34%,   /* matches narrower left panel */
    rgba(6,4,2,.90) 46%,
    rgba(6,4,2,.65) 60%,
    rgba(6,4,2,.30) 78%,
    rgba(6,4,2,.10) 100%
  );
  pointer-events: none;
}

/* ────────────────────────────────────────────
   CONTENT GRID — the structural backbone
   Two equal columns. Text in col-1 only.
   ──────────────────────────────────────────── */
.content-grid {
  position: relative;
  z-index: 10;
  height: 100%;
  /* 34 % text / 66 % bride — more room for the image */
  display: grid;
  grid-template-columns: 34% 66%;
}

/* ────────────────────────────────────────────
   LEFT COLUMN
   ──────────────────────────────────────────── */
.left-col {
  display: flex;
  flex-direction: column;
  justify-content: center;
  /* Top padding clears the fixed navbar */
  padding: 5.5rem clamp(1.5rem,3vw,2.5rem) 3rem clamp(2.5rem,6vw,5rem);
  /* Belt-and-braces: clip anything that might still overflow */
  overflow: hidden;
}

/* RIGHT COLUMN — empty on purpose */
.right-col { /* intentionally blank */ }

/* ── ✦ BRIDAL MAKEUP ✦ ──────────────────────────────────── */
.h-label {
  display: flex;
  align-items: center;
  gap: .55rem;
  margin-bottom: 1.6rem;
}
.h-orn {
  font-size: .65rem;
  color: #F2D060;
  flex-shrink: 0;
}
.h-label-text {
  font-family: 'DM Sans', sans-serif;
  font-size: clamp(.6rem, 1vw, .7rem);
  font-weight: 500;
  letter-spacing: .34em;
  text-transform: uppercase;
  color: #F2D060;
}

/* ── REIMAGINED AS ART ──────────────────────────────────── */
.h-reimagined {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(1.4rem, 2.4vw, 2rem);
  font-weight: 300;
  font-style: italic;
  color: rgba(250,246,240,.82);
  line-height: 1.1;
  letter-spacing: -.01em;
  margin: 0;
  text-shadow: 0 1px 12px rgba(6,4,2,.8);
}

/* ── GOLD RULE ───────────────────────────────────────────── */
.h-rule {
  width: 38px;
  height: 1px;
  background: linear-gradient(90deg, #D4AF37, transparent);
  opacity: .65;
  margin: 1.8rem 0;
}

/* ── SOLA SINGHAR — the payoff ───────────────────────────── */
.h-brand {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(2.8rem, 5.2vw, 4.8rem);
  font-weight: 300;
  color: #F2D060;
  letter-spacing: .07em;
  line-height: 1;
  margin-bottom: .75rem;
  text-shadow: 0 2px 20px rgba(6,4,2,.6);
}

/* ── BY UZMA MALIK — same tone as Reimagined ─────────────── */
.h-credit {
  font-family: 'DM Sans', sans-serif;
  font-size: clamp(.55rem, .9vw, .65rem);
  font-weight: 400;
  letter-spacing: .28em;
  text-transform: uppercase;
  color: rgba(250,246,240,.80);
  margin-bottom: 0;
  text-shadow: 0 1px 8px rgba(6,4,2,.7);
}

/* ────────────────────────────────────────────
   CTA BUTTONS
   ──────────────────────────────────────────── */
.cta-row {
  display: flex;
  gap: 1rem;
  flex-wrap: wrap;
  margin-top: 5.5rem;
}

.btn-fill,
.btn-line {
  font-family: 'DM Sans', sans-serif;
  font-size: .58rem;
  font-weight: 600;
  letter-spacing: .25em;
  text-transform: uppercase;
  text-decoration: none;
  padding: 1rem 2rem;
  white-space: nowrap;
  display: inline-flex;
  align-items: center;
  gap: .55rem;
  position: relative;
  overflow: hidden;
  transition: all .5s cubic-bezier(.19,1,.22,1);
}

/* Gold filled — primary CTA */
.btn-fill {
  background: linear-gradient(135deg, #C9A840 0%, #F2D060 45%, #C9A840 100%);
  background-size: 200% 100%;
  border: 1px solid #D4AF37;
  color: #0a0805;
  box-shadow: 0 4px 20px rgba(212,175,55,.25), inset 0 1px 0 rgba(255,255,255,.15);
}
.btn-fill::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, #F2D060 0%, #C9A840 100%);
  opacity: 0;
  transition: opacity .5s ease;
}
.btn-fill:hover {
  background-position: 100% 0;
  transform: translateY(-3px);
  box-shadow: 0 14px 36px rgba(212,175,55,.4), inset 0 1px 0 rgba(255,255,255,.2);
  letter-spacing: .3em;
}
.btn-fill:hover::before { opacity: 1; }
.btn-fill .btn-icon,
.btn-fill span { position: relative; z-index: 1; }

/* Ghost / outline — secondary CTA */
.btn-line {
  background: transparent;
  border: 1px solid rgba(212,175,55,.45);
  color: rgba(250,246,240,.85);
}
.btn-line::after {
  content: '';
  position: absolute;
  inset: 0;
  background: rgba(212,175,55,.08);
  transform: scaleX(0);
  transform-origin: left;
  transition: transform .45s cubic-bezier(.19,1,.22,1);
}
.btn-line:hover {
  border-color: #D4AF37;
  color: #F2D060;
  transform: translateY(-3px);
  box-shadow: 0 8px 24px rgba(212,175,55,.15);
}
.btn-line:hover::after { transform: scaleX(1); }

.btn-arrow {
  display: inline-block;
  transition: transform .4s cubic-bezier(.19,1,.22,1);
  position: relative; z-index: 1;
}
.btn-line:hover .btn-arrow { transform: translateX(5px); }

/* ────────────────────────────────────────────
   AWARD BADGE — bottom-right, over the bride
   ──────────────────────────────────────────── */
.award {
  position: absolute;
  bottom: clamp(1.5rem,4vh,3rem);
  right: clamp(1.5rem,3.5vw,3rem);
  z-index: 12;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: .15rem;
  border: 1px solid rgba(212,175,55,.35);
  padding: .7rem 1rem;
  backdrop-filter: blur(8px);
  background: rgba(6,4,2,.25);
}
.aw-star { font-size: .55rem; color: #D4AF37; }
.aw-t {
  font-family: 'DM Sans', sans-serif;
  font-size: .44rem;
  letter-spacing: .2em;
  text-transform: uppercase;
  color: rgba(250,246,240,.72);
}
.aw-y {
  font-family: 'Cormorant Garamond', serif;
  font-size: 1rem;
  font-weight: 300;
  color: #D4AF37;
  line-height: 1;
}

/* ────────────────────────────────────────────
   SCROLL CUE
   ──────────────────────────────────────────── */
.scroll-cue {
  position: absolute;
  right: clamp(1.2rem,2.5vw,2rem);
  top: 50%;
  transform: translateY(-50%);
  z-index: 12;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 7px;
  opacity: 0;
  animation: fadein 1s ease 3s forwards;
}
@keyframes fadein { to { opacity: 1; } }

.sc-text {
  font-family: 'DM Sans', sans-serif;
  font-size: .42rem;
  letter-spacing: .3em;
  text-transform: uppercase;
  color: rgba(212,175,55,.5);
  writing-mode: vertical-rl;
}
.sc-bar {
  width: 1px;
  height: 48px;
  background: linear-gradient(to bottom, #D4AF37, transparent);
  transform-origin: top;
  animation: pulse 2s ease-in-out infinite;
}
@keyframes pulse {
  0%,100% { transform: scaleY(1);   opacity: .5; }
  50%      { transform: scaleY(.4); opacity: 1;  }
}

/* ────────────────────────────────────────────
   ENTRANCE ANIMATIONS
   ──────────────────────────────────────────── */
[data-r] { opacity: 0; transform: translateY(14px); }
[data-r="0"] { animation: up .9s cubic-bezier(.19,1,.22,1) .3s  forwards; }
[data-r="1"] { animation: up 1.1s cubic-bezier(.19,1,.22,1) .55s forwards; }
[data-r="2"] { animation: up .9s cubic-bezier(.19,1,.22,1) .85s forwards; }
[data-r="3"] { animation: up .9s cubic-bezier(.19,1,.22,1) 1.05s forwards; }
[data-r="4"] { animation: up .9s cubic-bezier(.19,1,.22,1) 1.25s forwards; }
[data-r="5"] { animation: up .9s cubic-bezier(.19,1,.22,1) 1.5s forwards; }
[data-r="6"] { animation: up .9s cubic-bezier(.19,1,.22,1) 1.75s forwards; }
[data-r="7"] { animation: up .9s cubic-bezier(.19,1,.22,1) 2.2s forwards; }
@keyframes up { to { opacity: 1; transform: translateY(0); } }

/* ════════════════════════════════════════════
   RESPONSIVE
   ════════════════════════════════════════════ */

/* Wider screens: shrink text col slightly */
@media (min-width: 1400px) {
  .content-grid { grid-template-columns: 40% 60%; }
}

/* Tablet */
@media (max-width: 1024px) {
  .content-grid { grid-template-columns: 54% 46%; }
  .award        { display: none; }
  .scroll-cue   { display: none; }
}

/* ── TABLET ─────────────────────────────────────────────────── */
@media (max-width: 768px) {
  .content-grid { grid-template-columns: 60% 40%; }

  .h-brand { font-size: clamp(2.2rem, 8vw, 3.2rem); }
  .h-reimagined { font-size: clamp(1.1rem, 3.5vw, 1.5rem); }

  .cta-row { margin-top: 2.5rem; }
}

/* ── MOBILE ─────────────────────────────────────────────────── */
@media (max-width: 640px) {

  /* Full-screen single column, text pinned to bottom third */
  .content-grid {
    grid-template-columns: 1fr;
    grid-template-rows: 1fr;
    align-items: end;
  }
  .right-col { display: none; }

  /* Bride fills the full screen — face centred top half */
  .bg-img { object-position: 50% 15%; }

  /* Nav-cover: much thinner on mobile, just covers the navbar */
  .nav-cover {
    height: 70px;
    background: linear-gradient(
      to bottom,
      rgba(6,4,2,.75) 0%,
      transparent     100%
    );
  }

  /* Bottom scrim — text reads over bride's dress, face stays clear */
  .scrim {
    background: linear-gradient(
      to top,
      rgba(6,4,2,.98)  0%,
      rgba(6,4,2,.92) 25%,
      rgba(6,4,2,.70) 45%,
      rgba(6,4,2,.25) 62%,
      transparent      78%
    );
  }

  /* Text block sits at the bottom */
  .left-col {
    justify-content: flex-end;
    padding: 0 1.6rem 2.8rem;
    overflow: visible;
  }

  /* Tighter spacing between text elements on mobile */
  .h-label    { margin-bottom: .9rem; }
  .h-rule     { margin: 1rem 0; }
  .h-brand    { font-size: clamp(2.4rem, 11vw, 3.4rem); margin-bottom: .4rem; }
  .h-reimagined { font-size: clamp(1rem, 4.5vw, 1.3rem); }
  .h-credit   { font-size: .6rem; }

  /* Buttons: full width, stacked, reasonable height */
  .cta-row {
    flex-direction: column;
    gap: .75rem;
    margin-top: 1.8rem;
  }
  .btn-fill,
  .btn-line {
    width: 100%;
    justify-content: center;
    padding: .95rem 1.5rem;
    font-size: .62rem;
  }

  .award      { display: none; }
  .scroll-cue { display: none; }
}

/* ── SMALL PHONES (iPhone SE etc.) ────────────────────────── */
@media (max-width: 390px) {
  .h-brand  { font-size: 2.2rem; }
  .left-col { padding: 0 1.2rem 2.2rem; }
}
</style>
